@model IEnumerable<TestProjectMVC.Models.ProductViewModel>
@{
    ViewData["Title"] = "Products";
}

<h1 class="mb-4">Products</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">No products available.</div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                        <img src="@product.Image" class="card-img-top p-3" alt="@product.Title"
                             style="height: 200px; object-fit: contain;" />
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">
                            <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none text-dark">
                                @(product.Title.Length > 60 ? product.Title[..60] + "..." : product.Title)
                            </a>
                        </h6>
                        <p class="text-muted small mb-1">@product.Category</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold fs-5 text-success">$@product.Price.ToString("F2")</span>
                                <span class="text-warning small">
                                    &#9733; @product.Rating.Rate.ToString("F1")
                                    <span class="text-muted">(@product.Rating.Count)</span>
                                </span>
                            </div>
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm w-100 mt-2">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
